MODE=development # development, test, production
ORIGIN=https://example.com  # base url of server
API_URL=http://localhost:8000/graphql  # GraphQL endpoint web-next reads at runtime
DATABASE_URL=postgresql://localhost/hackerspub
KV_URL=file:///tmp/kv.db
SECRET_KEY=  # openssl rand -hex 32
INSTANCE_ACTOR_KEY=  # mise run keygen
BEHIND_PROXY=false
DRIVE_DISK=fs  # fs or s3
# In case of fs:
FS_LOCATION=./media
# In case of s3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_CDN_URL=
# S3_BUCKET=
# AWS_REGION=
MAILGUN_KEY=
MAILGUN_REGION=us
MAILGUN_DOMAIN=
MAILGUN_FROM=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
PLAUSIBLE=false
SENTRY_DSN=  # web-next picks this up at build time (client bundle) and runtime (server)
LOG_QUERY=false
LOG_FEDIFY=false
# graphql requires EMAIL_FROM or MAILGUN_FROM
EMAIL_FROM=admin@example.com
FUTURE_TIMESTAMP_TOLERANCE=300000
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_SIGNING_KEY=
APNS_DEFAULT_TOPIC=
# APNS_HOST=api.sandbox.push.apple.com
GOOGLE_SERVICES_JSON_BASE64=
# Firebase service account JSON, base64-encoded.
# Generate with: `base64 -i path/to/serviceAccountKey.json | tr -d '\n'`
